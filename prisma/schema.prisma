generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  hashed_password    String
  trial_start_date   DateTime @default(now())
  trial_ends_at      DateTime
  is_pro             Boolean  @default(false)
  stripe_customer_id String?  @unique

  stores       Store[]
  subscription Subscription?
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Store {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  name                     String  @default("My Store")
  slug                     String  @unique
  shopify_domain           String
  shopify_storefront_token String
  shopify_admin_token      String
  is_active                Boolean @default(true)

  // Enhanced Search (Pinecone RAG) Toggles
  enhanced_search_enabled Boolean   @default(false)
  rag_index_status        String    @default("idle") // idle, building, ready, error
  rag_last_indexed_at     DateTime?

  chatSessions ChatSession[]
  searchLogs   SearchLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Subscription {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  stripe_subscription_id String   @unique
  status                 String // e.g. "active", "canceled", "past_due"
  current_period_end     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WebhookLog {
  id          String @id @default(uuid())
  topic       String
  shop_domain String

  // Idempotency fields
  webhook_id   String? @unique // Shopify provides X-Shopify-Webhook-Id
  payload_hash String
  reference_id String? // e.g. product_id for granular deduplication

  status       String    @default("received")
  received_at  DateTime  @default(now())
  processed_at DateTime?
  error_msg    String?
}

model ChatSession {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  store_id String?
  store    Store?  @relation(fields: [store_id], references: [id])
  title    String?
  messages Json    @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([store_id])
}

model SearchLog {
  id               String   @id @default(cuid())
  storeId          String
  store            Store    @relation(fields: [storeId], references: [id])
  sessionId        String?
  query            String?
  hasImage         Boolean  @default(false)
  provider         String // "pinecone" | "shopify_native" | "hybrid"
  resultsCount     Int
  pineconeScores   Float[] // top match scores from Pinecone
  fallbackUsed     Boolean  @default(false)
  latencyMs        Int
  userFeedback     Int? // null | 1 (thumbs up) | -1 (thumbs down)
  clickedProductId String?
  createdAt        DateTime @default(now())

  @@index([storeId])
  @@index([createdAt])
}
