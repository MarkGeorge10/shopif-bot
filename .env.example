# ──────────────────────────────────────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection String (URI mode)
DATABASE_URL=postgresql://postgres:Toty@mark_22@db.impsvqjdizhzspvwgodk.supabase.co:5432/postgres

# ──────────────────────────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-256-bit-hex-value
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ──────────────────────────────────────────────────────────────────────────────
# ENCRYPTION (for Shopify access tokens stored in DB)
# ──────────────────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET_KEY=generate-me-with-the-command-above

# ──────────────────────────────────────────────────────────────────────────────
# STRIPE
# ──────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The Price ID for your $20/month recurring product in Stripe Dashboard
STRIPE_PRICE_ID=price_...

# ──────────────────────────────────────────────────────────────────────────────
# SHOPIFY OAUTH (from Shopify Partner Dashboard → Your App)
# ──────────────────────────────────────────────────────────────────────────────
SHOPIFY_CLIENT_ID=your-shopify-app-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-app-client-secret
SHOPIFY_SCOPES=read_products,write_cart,read_orders,read_customers

# ──────────────────────────────────────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────────────────────────────────────
# The public URL where THIS backend is deployed (no trailing slash)
APP_URL=https://your-backend.onrender.com
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# TRIAL SETTINGS
# ──────────────────────────────────────────────────────────────────────────────
TRIAL_DAYS=14
